# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/autoencoder_portal
MONGO_DEBUG=false

# JWT Authentication
JWT_SECRET=autoencoder_jwt_secret_key_2024_secure_random_string_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=autoencoder_refresh_secret_key_2024_secure_random_string_here
JWT_REFRESH_EXPIRES_IN=7d

# Python Backend (Autoencoder Service)
PYTHON_BACKEND_URL=http://localhost:8000
PYTHON_BACKEND_TIMEOUT=30000
PYTHON_BACKEND_RETRY_ATTEMPTS=3
PYTHON_BACKEND_HEALTH_CHECK_INTERVAL=60000

# Scrambler Settings (For PRNG)
SCRAMBLER_KEY=autoencoder_master_scrambler_key_2024_secure_random_string_change_in_production
SCRAMBLER_ALGORITHM=AES-256-GCM
SCRAMBLER_IV_LENGTH=16

# Bcrypt Settings
BCRYPT_SALT_ROUNDS=10

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/dicom

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Security
SESSION_SECRET=autoencoder_session_secret_2024_secure_random_string_here
ENCRYPTION_KEY=autoencoder_encryption_key_2024_32_bytes_required_here

# API Rate Limits
API_RATE_LIMIT_AUTH=5  # requests per minute for auth endpoints
API_RATE_LIMIT_GENERAL=60  # requests per minute for general endpoints

# Backup MongoDB (Optional)
# MONGO_URI_BACKUP=mongodb://localhost:27017/autoencoder_backup